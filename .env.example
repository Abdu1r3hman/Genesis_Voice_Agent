# Copy this file to ".env" and fill in your key.
# Get a free Groq API key at https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key_here

# Optional overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile          # reply model (use llama-3.1-8b-instant for faster/snappier)
# GROQ_UNDERSTAND_MODEL=llama-3.1-8b-instant  # fast structured-query extraction
# USE_LLM_UNDERSTANDING=1                      # set 0 to use the regex parser only
